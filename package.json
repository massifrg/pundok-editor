{
  "name": "pundok-editor",
  "version": "0.15.0",
  "author": "mf",
  "homepage": "https://github.com/massifrg/pundok-editor",
  "description": "A visual editor for Pandoc AST documents",
  "private": true,
  "engines": {
    "node": ">=v16.13",
    "npm": ">=8.1"
  },
  "main": "packages/main/dist/index.cjs",
  "scripts": {
    "format": "prettier --write \"**/*.{js,ts,vue,scss,html,md,json}\" --ignore-path .gitignore",
    "build": "npm run build:common && npm run build:main && npm run build:preload && npm run build:renderer",
    "build:common": "cd ./packages/common && vite build",
    "build:main": "cd ./packages/main && vite build",
    "build:preload": "cd ./packages/preload && vite build",
    "build:preload:types": "dts-cb -i \"packages/preload/tsconfig.json\" -o \"packages/preload/exposedInMainWorld.d.ts\"",
    "build:renderer": "cd ./packages/renderer && vite build",
    "compile": "cross-env MODE=production npm run build && electron-builder build --config .electron-builder.config.js --dir --config.asar=false",
    "pre-dist": "echo \"hack to prevent canvas recompilation, see https://github.com/Automattic/node-canvas/issues/2375#issuecomment-2141619136\"; rimraf node_modules/canvas",
    "dist": "npm run pre-dist; cross-env MODE=production npm run build && electron-builder build --config .electron-builder.config.js -wl --x64",
    "dist:linux": "npm run pre-dist; cross-env MODE=production npm run build && electron-builder build --config .electron-builder.config.js -l --x64",
    "dist:deb": "npm run pre-dist; cross-env MODE=production npm run build && electron-builder build --config .electron-builder.config.js --linux deb --x64",
    "dist:win": "npm run pre-dist; cross-env MODE=production npm run build && electron-builder build --config .electron-builder.config.js -w --x64",
    "dist:win32": "npm run pre-dist; cross-env MODE=production npm run build && electron-builder build --config .electron-builder.config.js -w --ia32",
    "docs": "npx typedoc",
    "test": "npm run test:main && npm run test:preload && npm run test:renderer && npm run test:e2e",
    "test:e2e": "npm run build && vitest run",
    "test:main": "vitest run -r packages/main --passWithNoTests",
    "test:preload": "vitest run -r packages/preload --passWithNoTests",
    "test:renderer": "vitest run -r packages/renderer --passWithNoTests",
    "dev": "npm run watch:renderer",
    "watch": "node scripts/watch.js",
    "watch:renderer": "cd ./packages/renderer && vite",
    "lint": "eslint . --ext js,ts,vue",
    "typecheck:main": "tsc --noEmit -p packages/main/tsconfig.json",
    "typecheck:preload": "tsc --noEmit -p packages/preload/tsconfig.json",
    "typecheck:renderer": "npm run build:preload:types && vue-tsc --noEmit -p packages/renderer/tsconfig.json",
    "typecheck": "npm run typecheck:main && npm run typecheck:preload && npm run typecheck:renderer",
    "start": "electron-forge start",
    "package": "electron-forge package",
    "make": "electron-forge make",
    "forge:make:all": "electron-forge make --arch=x64 --targets=@electron-forge/maker-squirrel,@electron-forge/maker-deb,@electron-forge/maker-zip",
    "schema:configuration": "cd schemas; ts-json-schema-generator -p ../packages/common/src/config/editorConfigInit.ts > pundok-configuration.schema.json",
    "schema:project": "cd schemas; ts-json-schema-generator -p ../packages/common/src/config/project.ts -t PundokEditorProject > pundok-project.schema.json",
    "schema": "npm run schema:configuration && npm run schema:project",
    "static:styles": "cd staticResources/css/scss; sass .:.. --no-source-map"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.11.1",
    "@electron-forge/maker-deb": "^7.11.1",
    "@electron-forge/maker-rpm": "^7.11.1",
    "@electron-forge/maker-squirrel": "^7.11.1",
    "@electron-forge/maker-wix": "^7.11.1",
    "@electron-forge/maker-zip": "^7.11.1",
    "@electron/asar": "^4.0.1",
    "@intlify/unplugin-vue-i18n": "^11.0.3",
    "@quasar/vite-plugin": "^1.10.0",
    "@types/axios": "^0.14.0",
    "@types/bluebird": "^3.5.42",
    "@types/drivelist": "^6.4.4",
    "@types/lodash": "^4.17.23",
    "@types/lodash-es": "^4.17.12",
    "@types/path-browserify": "^1.0.3",
    "@types/unzip-stream": "^0.3.4",
    "@types/webfontloader": "^1.6.38",
    "@types/yargs": "^17.0.35",
    "@typescript-eslint/eslint-plugin": "^8.53.0",
    "@typescript-eslint/parser": "^8.53.0",
    "@vitejs/plugin-vue": "^6.0.3",
    "cross-env": "^10.1.0",
    "dts-for-context-bridge": "0.7.1",
    "electron": "^40.0.0",
    "electron-builder": "^26.4.0",
    "electron-devtools-installer": "^4.0.0",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "^10.7.0",
    "happy-dom": "^20.3.1",
    "prettier": "^3.8.0",
    "ts-json-schema-generator": "^2.4.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vitest": "^4.0.17",
    "vue-tsc": "^3.2.2"
  },
  "dependencies": {
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/state": "^6.5.4",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.39.11",
    "@massifrg/prosemirror-tables-sections": "^0.6.3",
    "@quasar/extras": "^1.17.0",
    "@tiptap/core": "^3.15.3",
    "@tiptap/extension-blockquote": "^3.15.3",
    "@tiptap/extension-bullet-list": "^3.15.3",
    "@tiptap/extension-code-block-lowlight": "^3.15.3",
    "@tiptap/extension-document": "^3.15.3",
    "@tiptap/extension-gapcursor": "^3.15.3",
    "@tiptap/extension-hard-break": "^3.15.3",
    "@tiptap/extension-heading": "^3.15.3",
    "@tiptap/extension-history": "^3.15.3",
    "@tiptap/extension-horizontal-rule": "^3.15.3",
    "@tiptap/extension-link": "^3.15.3",
    "@tiptap/extension-list-item": "^3.15.3",
    "@tiptap/extension-ordered-list": "^3.15.3",
    "@tiptap/extension-paragraph": "^3.15.3",
    "@tiptap/extension-subscript": "^3.15.3",
    "@tiptap/extension-superscript": "^3.15.3",
    "@tiptap/extension-text": "^3.15.3",
    "@tiptap/extension-underline": "^3.15.3",
    "@tiptap/pm": "^3.15.3",
    "@tiptap/vue-3": "^3.15.3",
    "axios": "^1.13.2",
    "codemirror": "^6.0.2",
    "drivelist": "^12.0.2",
    "electron-squirrel-startup": "^1.0.1",
    "electron-updater": "^6.7.3",
    "highlight.js": "^11.11.1",
    "lodash": "^4.17.21",
    "lodash-es": "^4.17.22",
    "lowlight": "^3.3.0",
    "parsel-js": "^1.2.2",
    "path": "^0.12.7",
    "path-browserify": "^1.0.1",
    "pdfjs-dist": "^5.4.530",
    "pinia": "^3.0.4",
    "prosemirror-dev-toolkit": "^1.1.8",
    "quasar": "^2.18.6",
    "romanize-deromanize": "^2.0.2",
    "unzip-stream": "^0.3.4",
    "vue": "^3.5.26",
    "vue-codemirror": "^6.1.1",
    "vue-i18n": "^11.2.8",
    "vue-pdf-embed": "^2.1.2",
    "yargs": "^18.0.0",
    "zip-lib": "^1.1.2"
  },
  "nano-staged": {
    "*.{js,ts}": "prettier --write",
    "packages/**/*.css": [
      "stylelint",
      "eslint --fix"
    ]
  }
}
