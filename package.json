{
  "name": "pundok-editor",
  "version": "0.15.5",
  "author": "mf",
  "homepage": "https://github.com/massifrg/pundok-editor",
  "description": "A visual editor for Pandoc AST documents",
  "private": true,
  "engines": {
    "node": ">=v16.13",
    "npm": ">=8.1"
  },
  "type": "module",
  "main": "packages/main/dist/index.mjs",
  "scripts": {
    "format": "prettier --write \"**/*.{js,ts,vue,scss,html,md,json}\" --ignore-path .gitignore",
    "build": "npm run build:common && npm run build:main && npm run build:preload && npm run build:renderer",
    "build:common": "cd ./packages/common && vite build",
    "build:main": "cd ./packages/main && vite build",
    "build:preload": "cd ./packages/preload && vite build",
    "build:preload:types": "dts-cb -i \"packages/preload/tsconfig.json\" -o \"packages/preload/exposedInMainWorld.d.ts\"",
    "build:renderer": "cd ./packages/renderer && vite build",
    "compile": "cross-env MODE=production npm run build && electron-builder build --config electron-builder.mjs --dir --config.asar=false",
    "pre-dist": "echo \"hack to prevent canvas recompilation, see https://github.com/Automattic/node-canvas/issues/2375#issuecomment-2141619136\"; rimraf node_modules/canvas",
    "dist": "npm run pre-dist; cross-env MODE=production npm run build && electron-builder build --config electron-builder.mjs -wl --x64",
    "dist:linux": "npm run pre-dist; cross-env MODE=production npm run build && electron-builder build --config electron-builder.mjs -l --x64",
    "dist:deb": "npm run pre-dist; cross-env MODE=production npm run build && electron-builder build --config electron-builder.mjs --linux deb --x64",
    "dist:win": "npm run pre-dist; cross-env MODE=production npm run build && electron-builder build --config electron-builder.mjs -w --x64",
    "dist:win32": "npm run pre-dist; cross-env MODE=production npm run build && electron-builder build --config electron-builder.mjs -w --ia32",
    "docs": "npx typedoc",
    "test": "npm run test:main && npm run test:preload && npm run test:renderer && npm run test:e2e",
    "test:e2e": "npm run build && vitest run",
    "test:main": "vitest run -r packages/main --passWithNoTests",
    "test:preload": "vitest run -r packages/preload --passWithNoTests",
    "test:renderer": "vitest run -r packages/renderer --passWithNoTests",
    "dev": "npm run watch:renderer",
    "watch": "node scripts/watch.js",
    "watch:renderer": "cd ./packages/renderer && vite",
    "lint": "eslint . --ext js,ts,vue",
    "typecheck:main": "tsc --noEmit -p packages/main/tsconfig.json",
    "typecheck:preload": "tsc --noEmit -p packages/preload/tsconfig.json",
    "typecheck:renderer": "vue-tsc --noEmit -p packages/renderer/tsconfig.json",
    "typecheck": "npm run typecheck:main && npm run typecheck:preload && npm run typecheck:renderer",
    "start": "electron-forge start",
    "package": "electron-forge package",
    "make": "electron-forge make",
    "forge:make:all": "electron-forge make --arch=x64 --targets=@electron-forge/maker-squirrel,@electron-forge/maker-deb,@electron-forge/maker-zip",
    "schema:configuration": "cd schemas; ts-json-schema-generator -p ../packages/common/src/config/editorConfigInit.ts > pundok-configuration.schema.json",
    "schema:project": "cd schemas; ts-json-schema-generator -p ../packages/common/src/config/project.ts -t PundokEditorProject > pundok-project.schema.json",
    "schema": "npm run schema:configuration && npm run schema:project",
    "static:styles": "cd staticResources/css/scss; sass .:.. --no-source-map"
  },
  "devDependencies": {
    "@app/electron-versions": "file:packages/electron-versions",
    "@intlify/unplugin-vue-i18n": "^11.1.2",
    "@npmcli/map-workspaces": "^5.0.3",
    "@quasar/vite-plugin": "^1.11.0",
    "@types/axios": "^0.14.4",
    "@types/bluebird": "^3.5.42",
    "@types/lodash": "^4.17.24",
    "@types/lodash-es": "^4.17.12",
    "@types/path-browserify": "^1.0.3",
    "@types/unzip-stream": "^0.3.4",
    "@types/webfontloader": "^1.6.38",
    "@types/yargs": "^17.0.35",
    "@typescript-eslint/eslint-plugin": "^8.59.2",
    "@typescript-eslint/parser": "^8.59.2",
    "@vitejs/plugin-vue": "^6.0.6",
    "cross-env": "^10.1.0",
    "dts-for-context-bridge": "0.7.1",
    "electron": "^41.5.0",
    "electron-builder": "^26.9.0",
    "electron-devtools-installer": "^4.0.0",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "^10.9.0",
    "happy-dom": "^20.9.0",
    "prettier": "^3.8.3",
    "rollup-plugin-visualizer": "^7.0.1",
    "sass-embedded": "^1.99.0",
    "ts-json-schema-generator": "^2.9.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.10",
    "vite-bundle-analyzer": "^1.3.8",
    "vitest": "^4.1.5",
    "vue-tsc": "^3.2.8"
  },
  "dependencies": {
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/state": "^6.6.0",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.41.1",
    "@massifrg/prosemirror-tables-sections": "^0.6.3",
    "@quasar/extras": "^1.18.0",
    "@recent-cli/jumplist-parser-lite": "^0.0.1",
    "@tiptap/core": "^3.22.5",
    "@tiptap/extension-blockquote": "^3.22.5",
    "@tiptap/extension-bullet-list": "^3.22.5",
    "@tiptap/extension-code-block": "^3.22.5",
    "@tiptap/extension-code-block-lowlight": "^3.22.5",
    "@tiptap/extension-document": "^3.22.5",
    "@tiptap/extension-gapcursor": "^3.22.5",
    "@tiptap/extension-hard-break": "^3.22.5",
    "@tiptap/extension-heading": "^3.22.5",
    "@tiptap/extension-history": "^3.22.5",
    "@tiptap/extension-horizontal-rule": "^3.22.5",
    "@tiptap/extension-link": "^3.22.5",
    "@tiptap/extension-list-item": "^3.22.5",
    "@tiptap/extension-ordered-list": "^3.22.5",
    "@tiptap/extension-paragraph": "^3.22.5",
    "@tiptap/extension-subscript": "^3.22.5",
    "@tiptap/extension-superscript": "^3.22.5",
    "@tiptap/extension-text": "^3.22.5",
    "@tiptap/extension-underline": "^3.22.5",
    "@tiptap/pm": "^3.22.5",
    "@tiptap/vue-3": "^3.22.5",
    "axios": "^1.16.0",
    "codemirror": "^6.0.2",
    "electron-updater": "^6.8.3",
    "highlight.js": "^11.11.1",
    "lodash-es": "^4.18.1",
    "lowlight": "^3.3.0",
    "node-disk-info": "^1.3.0",
    "parsel-js": "^1.2.2",
    "path-browserify": "^1.0.1",
    "pinia": "^3.0.4",
    "prosemirror-dev-toolkit": "^1.1.8",
    "quasar": "^2.19.3",
    "romanize-deromanize": "^2.1.0",
    "unzip-stream": "^0.3.4",
    "vue": "^3.5.33",
    "vue-codemirror": "^6.1.1",
    "vue-i18n": "^11.4.4",
    "vue-pdf-embed": "^2.1.4",
    "yargs": "^18.0.0",
    "zip-lib": "^1.3.2"
  },
  "nano-staged": {
    "*.{js,ts}": "prettier --write",
    "packages/**/*.css": [
      "stylelint",
      "eslint --fix"
    ]
  }
}
